{
  "name": "bcgov/moodle-php-dependencies",
  "description": "Additional PHP dependencies for Moodle deployment - Security-controlled versions",
  "type": "project",
  "require": {
    "maennchen/zipstream-php": "2.4.1"
  },
  "require-dev": {},
  "config": {
    "optimize-autoloader": true,
    "prefer-stable": true,
    "sort-packages": true,
    "audit": {
      "abandoned": "report"
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "scripts": {
    "security-audit": "composer audit --format=json",
    "security-check": "composer audit --format=table",
    "validate-lock": "composer validate --strict --check-lock",
    "update-deps": "composer update --with-all-dependencies --dry-run"
  },
  "authors": [
    {
      "name": "Infrastructure Team",
      "email": "infrastructure@gov.bc.ca"
    }
  ],
  "license": "Apache-2.0"
}