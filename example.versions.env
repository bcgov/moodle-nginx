# Time limit to build new images for Artifactory
IMAGE_REBUILD_TIME_LIMIT=86400 # 24 hours in seconds

# =============================================================================
# CENTRALIZED VERSION MANAGEMENT
# Single source of truth for all dependency versions across the platform
#
# AUTOMATED DEPENDENCY MANIFESTS (generated during builds):
# • NPM dependencies: config/lighthouse/package.json (Dependabot scans)
# • PHP dependencies: config/moodle/composer.json (Dependabot scans)
# • Container images: openshift/dependencies/images.yml (Dependabot scans)
# • Helm charts: openshift/dependencies/Chart.yaml (Dependabot scans)
# • Security tools: .github/security-tools.json (Custom security scans)
# • Git dependencies: config/moodle/git-dependencies.json (Custom security scans)
# • Local development: .env.generated (docker-compose integration)
#
# GENERATION: Run ./openshift/scripts/populate-dependency-manifests.sh
# OR: Use ./setup-local-dev.sh for local development setup
# =============================================================================

# Base images for containers (managed by Dependabot)
PHP_IMAGE=php:8.1-fpm
CRON_IMAGE=php:8.1-cli
DB_IMAGE=mariadb:10
WEB_IMAGE=nginxinc/nginx-unprivileged:1-alpine-slim
BACKUP_HELM_CHART=bcgov/backup-storage
BACKUP_IMAGE=bcgovimages/backup-container-mariadb:latest
REDIS_HELM_CHART=bitnami/redis
REDIS_CHART_VERSION=23.1.3
REDIS_IMAGE=bitnamilegacy/redis:8.0.2-debian-12-r2
REDIS_SENTINEL_IMAGE=bitnamilegacy/redis-sentinel:8.0.2-debian-12-r1
GOLANG_IMAGE=golang:1.12
UBUNTU_IMAGE=ubuntu:24.04

# PHP Composer dependencies
# Core system dependencies and security-critical packages centralized here:
COMPOSER_VERSION=2.7.7
PHP_CODESNIFFER_VERSION=^3.7

# Application PHP Dependencies (security-controlled versions)
# These are managed centrally for supply chain security
ZIPSTREAM_PHP_VERSION=2.4.1  # Fixed version for security validation

# NPM dependencies for Lighthouse testing
# NOTE: NPM versions are managed in config/lighthouse/package.json
# This allows Dependabot to automatically update NPM dependencies
# while keeping other versions centralized here

# Security scanning tools
TRIVY_VERSION=latest
DOCKER_SCOUT_VERSION=latest

# Version control for Moodle and plugins
MOODLE_URL="https://github.com/moodle/moodle"
MOODLE_BRANCH_VERSION=MOODLE_401_STABLE
HVP_URL="https://github.com/h5p/moodle-mod_hvp"
HVP_BRANCH_VERSION=stable
PSAELMSYNC_URL="https://github.com/bcgov/psaelmsync"
PSAELMSYNC_BRANCH_VERSION=main
REPORT_ALL_BACKUPS_URL="https://github.com/catalyst/moodle-report_allbackups"
REPORT_ALL_BACKUPS_BRANCH_VERSION=MOODLE_400_STABLE
THEME_BRANCH_VERSION=main
THEME_URL="https://github.com/bcgov/bcgovpsa-moodle"
PCURATOR_URL="https://github.com/itr8tech/pathcurator-moodle/"
PCURATOR_BRANCH_VERSION=main
COURSESEARCH_URL="https://github.com/bcgov/moodle-course-search/"
COURSESEARCH_BRANCH_VERSION=main
